# Copy to .env and fill in your values

# Required for Postgres on Render/Railway. Leave blank for local SQLite.
DATABASE_URL=

# Flask secret. Use a long random string in production.
SECRET_KEY=change-me-to-a-long-random-string

# First admin (auto-seeded on first run)
ADMIN_EMAIL=admin@spoteasy.in
ADMIN_PASSWORD=Admin@1234

# Email (Gmail App Password) — optional. Required to receive email notifications.
EMAIL_FROM=
EMAIL_KEY=

# Public URL — auto-detected on Railway/Render. Override here if needed.
SITE_URL=
