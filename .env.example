# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Supabase PostgreSQL connection string
# Get this from: Supabase → Project Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres

# Super Admin login credentials (created automatically on first run)
SUPER_ADMIN_EMAIL=admin@parksmart.in
SUPER_ADMIN_PASSWORD=Admin@123

# CORS allowed origins (use * for development, your domain for production)
ALLOWED_ORIGINS=*
